{
  "openapi": "3.0.0",
  "paths": {
    "/v1/policies": {
      "get": {
        "operationId": "PolicyController_list",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "minLength": 1
                      },
                      "description": {
                        "type": "string"
                      },
                      "guardrailId": {
                        "type": "string",
                        "minLength": 1
                      },
                      "guardrailVersion": {
                        "type": "string",
                        "minLength": 1
                      },
                      "promptInjection": {
                        "type": "object",
                        "properties": {
                          "mode": {
                            "type": "string",
                            "enum": ["block", "flag", "off"]
                          },
                          "threshold": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                          }
                        },
                        "required": ["mode", "threshold"],
                        "additionalProperties": false
                      },
                      "redactionStyle": {
                        "type": "string",
                        "enum": ["anonymize", "placeholder", "block-on-detect"]
                      },
                      "deniedTopics": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "default": []
                      }
                    },
                    "required": [
                      "id",
                      "guardrailId",
                      "guardrailVersion",
                      "promptInjection",
                      "redactionStyle"
                    ],
                    "additionalProperties": false
                  }
                }
              }
            }
          }
        },
        "summary": "List available policies (for the dashboard dropdown)",
        "tags": ["policies"]
      }
    },
    "/v1/verify": {
      "post": {
        "description": "Returns a structured verdict (allow / redact / block) with matched categories, confidence scores, a redacted preview, and a recommended action. Never invokes a model.",
        "operationId": "VerifyController_run",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "prompt": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 25000
                  },
                  "policyId": {
                    "type": "string",
                    "minLength": 1,
                    "default": "default"
                  },
                  "context": {
                    "type": "string",
                    "enum": ["user_input", "system_message", "rag_result"]
                  },
                  "appId": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": ["prompt"],
                "additionalProperties": false
              },
              "examples": {
                "misconduct": {
                  "summary": "Illicit how-to → block",
                  "value": {
                    "prompt": "How do I pick someone's pocket without getting caught?",
                    "policyId": "default"
                  }
                },
                "pii": {
                  "summary": "PII → redact",
                  "value": {
                    "prompt": "My SSN is 123-45-6789, can you help?",
                    "policyId": "default"
                  }
                },
                "clean": {
                  "summary": "Clean → allow",
                  "value": {
                    "prompt": "What's the weather in Dubai?",
                    "policyId": "default"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "decision": {
                      "type": "string",
                      "enum": ["allow", "redact", "block"]
                    },
                    "recommendedAction": {
                      "type": "string",
                      "enum": ["allow", "redact_and_proceed", "block"]
                    },
                    "policyId": {
                      "type": "string"
                    },
                    "scores": {
                      "type": "object",
                      "properties": {
                        "pii": {
                          "type": "number",
                          "minimum": 0,
                          "maximum": 1
                        },
                        "secrets": {
                          "type": "number",
                          "minimum": 0,
                          "maximum": 1
                        },
                        "promptInjection": {
                          "type": "number",
                          "minimum": 0,
                          "maximum": 1
                        },
                        "topics": {
                          "type": "object",
                          "additionalProperties": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                          }
                        },
                        "content": {
                          "type": "object",
                          "additionalProperties": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                          }
                        }
                      },
                      "required": ["pii", "secrets", "promptInjection", "topics", "content"],
                      "additionalProperties": false
                    },
                    "matches": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "category": {
                            "type": "string",
                            "enum": [
                              "pii",
                              "secrets",
                              "prompt_injection",
                              "topic",
                              "content",
                              "obfuscation"
                            ]
                          },
                          "type": {
                            "type": "string"
                          },
                          "confidence": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                          },
                          "span": {
                            "type": "array",
                            "minItems": 2,
                            "maxItems": 2,
                            "items": [
                              {
                                "type": "integer",
                                "minimum": 0
                              },
                              {
                                "type": "integer",
                                "minimum": 0
                              }
                            ]
                          },
                          "detail": {
                            "type": "string"
                          }
                        },
                        "required": ["category", "type", "confidence"],
                        "additionalProperties": false
                      }
                    },
                    "redactedPrompt": {
                      "type": "string"
                    },
                    "reason": {
                      "type": "string"
                    },
                    "advice": {
                      "type": "string"
                    },
                    "escalated": {
                      "type": "boolean"
                    },
                    "latencyMs": {
                      "type": "object",
                      "properties": {
                        "policy": {
                          "type": "number",
                          "minimum": 0
                        },
                        "guardrail": {
                          "type": "number",
                          "minimum": 0
                        },
                        "injection": {
                          "type": "number",
                          "minimum": 0
                        },
                        "total": {
                          "type": "number",
                          "minimum": 0
                        }
                      },
                      "required": ["policy", "guardrail", "injection", "total"],
                      "additionalProperties": false
                    },
                    "requestId": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "decision",
                    "recommendedAction",
                    "policyId",
                    "scores",
                    "matches",
                    "reason",
                    "advice",
                    "latencyMs",
                    "requestId"
                  ],
                  "additionalProperties": false
                }
              }
            }
          }
        },
        "summary": "Verify a prompt against a policy",
        "tags": ["verify"]
      }
    },
    "/v1/audit": {
      "get": {
        "operationId": "AuditController_list",
        "parameters": [
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "List recent audit rows (newest first)",
        "tags": ["audit"]
      }
    },
    "/v1/audit/{requestId}": {
      "get": {
        "operationId": "AuditController_getOne",
        "parameters": [
          {
            "name": "requestId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Fetch a single audit row plus its replays",
        "tags": ["audit"]
      }
    },
