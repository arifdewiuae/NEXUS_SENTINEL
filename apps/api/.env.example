# --- Runtime ---
NODE_ENV=development
# API listens on 5050; the web dashboard runs on 5051.
PORT=5050
LOG_LEVEL=info

# Adapter set: `fake` runs fully offline (default); `aws` uses Bedrock + DynamoDB.
PROVIDER=fake

# --- Open-endpoint controls ---
# When set, POST /v1/* requires this value in the `x-api-key` header. Leave unset for an open demo.
# API_KEY=change-me
# Comma-separated CORS allowlist. `*` is fine for the public demo.
CORS_ORIGINS=*
# Coarse per-IP burst throttle (in-memory @nestjs/throttler).
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_LIMIT=60

# --- Cost limiter (shared-state: DynamoDB on aws, in-memory on fake) ---
# Caps billable Bedrock calls per user (x-client-id), per IP, and globally.
# Set RATE_LIMIT_ENABLED=false to disable (or use PROVIDER=fake as the kill switch).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_USER_PER_HOUR=20
RATE_LIMIT_USER_PER_DAY=60
RATE_LIMIT_IP_PER_HOUR=40
RATE_LIMIT_IP_PER_DAY=120
RATE_LIMIT_GLOBAL_PER_DAY=2000

# --- Fan-out timeouts ---
GUARDRAIL_TIMEOUT_MS=1500
INJECTION_TIMEOUT_MS=3000

# --- AWS (required only when PROVIDER=aws) ---
# AWS_REGION=eu-north-1
# AUDIT_TABLE_NAME=nexus-sentinel-audit
# RATE_LIMIT_TABLE_NAME=nexus-sentinel-ratelimit   # required when PROVIDER=aws and RATE_LIMIT_ENABLED
# BEDROCK_HAIKU_MODEL_ID=eu.anthropic.claude-haiku-4-5-20251001-v1:0
# BEDROCK_HAIKU_FALLBACK_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0
# BEDROCK_MAX_ATTEMPTS=3
